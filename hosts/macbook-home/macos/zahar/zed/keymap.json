[
  // Global bindigns start
  {
    "bindings": {
      "cmd-h": "pane::ActivatePreviousItem",
      "cmd-l": "pane::ActivateNextItem",

      "ctrl-e": "workspace::ToggleLeftDock",
      "ctrl-t": "workspace::ToggleBottomDock",

      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w j": "workspace::ActivatePaneDown",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w l": "workspace::ActivatePaneRight",
    },
  },
  // Global bindings end

  // Editor start
  {
    "context": "Editor && (showing_code_actions || showing_completions)",
    "bindings": {
      "ctrl-tab": "editor::ContextMenuPrevious",
      "tab": "editor::ContextMenuNext",
    },
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual || vim_mode == insert)",
    "bindings": {
      "ctrl-h": "vim::Left",
      "ctrl-j": "vim::Down",
      "ctrl-k": "vim::Up",
      "ctrl-l": "vim::Right",
    },
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "E": "vim::EndOfLineDownward",
      "Q": "vim::StartOfLineDownward",
      "q": "vim::PreviousWordEnd",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "; t": "editor::ToggleBreakpoint",
      "; r": "debugger::Start",
      "; c": "debugger::ClearAllBreakpoints",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "cmd-c": ["workspace::SendKeystrokes", "y"], // rebind to reset the selection
      "tab": "editor::Indent",
      "shift-tab": "editor::Outdent",
    },
  },
  // Editor end

  // Terminal start
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": ["workspace::SendKeystrokes", "left"],
      "ctrl-j": ["workspace::SendKeystrokes", "down"],
      "ctrl-k": ["workspace::SendKeystrokes", "up"],
      "ctrl-l": ["workspace::SendKeystrokes", "right"],
    },
  },
  // Terminal end

  // ProjectPanel start
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "o": "project_panel::OpenPermanent",
      "s": "project_panel::OpenSplitVertical",
      "shift-i": "project_panel::ToggleHideHidden",
    },
  },
  // ProjectPanel end
]
