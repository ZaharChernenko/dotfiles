{
  "cli_default_open_behavior": "new_window",
  "disable_ai": true,
  "vim_mode": true,

  // UI start
  "ui_font_family": ".ZedSans",
  "ui_font_size": 16.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Fleet Dark",
  },
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
  // UI end

  // Bars start
  "title_bar": {
    "show_menus": false,
    "show_project_items": true,
    "show_branch_status_icon": false,
    "show_branch_name": true,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "close_position": "left",
    "file_icons": false,
    "git_status": false,
    "show_close_button": "always",
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "status_bar": {
    "active_language_button": true,
  },
  "bottom_dock_layout": "contained",
  // Bars end

  // Panels start
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "debugger": {
    "button": true,
    "dock": "left",
  },
  "git_panel": {
    "button": true,
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
    "button": false,
  },
  "project_panel": {
    "dock": "left",
    "hide_hidden": false,
    "auto_reveal_entries": false,
    "default_width": 240.0,
    "button": true,
  },
  // Panels end

  // Editor start
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 13.0,
  "buffer_font_features": {
    "calt": false,
  },
  "cursor_shape": "bar",
  "completions": {
    "words": "fallback",
  },
  "completion_menu_scrollbar": "auto",
  "diagnostics": {
    "lsp_pull_diagnostics": {
      "debounce_ms": 350,
    },
    "inline": {
      "update_debounce_ms": 350,
      "enabled": false,
    },
    "button": true,
    "include_warnings": true,
  },
  "ensure_final_newline_on_save": true,
  "hover_popover_delay": 175,
  "inlay_hints": {
    "enabled": false,
  },
  "snippet_sort_order": "top",
  "wrap_guides": [100],
  // Editor end

  "terminal": {
    "keep_selection_on_copy": true,
    "alternate_scroll": "on",
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_size": 14.0,
    "font_family": "MesloLGS NF",
  },

  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },

  "languages": {
    "Shell Script": {
      "language_servers": ["bash-language-server"],
    },
    "C++": {
      "language_servers": ["clangd"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "clangd" } }],
    },
    "CMake": {
      "language_servers": ["cmake"],
    },
    "Markdown": { "format_on_save": "on", "formatter": "prettier" },
    "Python": {
      "language_servers": ["basedpyright", "ruff", "pylsp"],
      "format_on_save": "on",
      "formatter": [
        { "code_action": "source.organizeImports.ruff" },
        { "code_action": "source.fixAll.ruff" },
        { "language_server": { "name": "ruff" } },
      ],
    },
  },

  "lsp": {
    "pylsp": {
      "settings": {
        "plugins": {
          "pylint": { "enabled": true, "executable": "pylint" },
          "jedi_completion": { "enabled": false },
          "jedi_definition": { "enabled": false },
          "jedi_hover": { "enabled": false },
          "jedi_references": { "enabled": false },
          "jedi_signature_help": { "enabled": false },
          "jedi_symbols": { "enabled": false },
          "pyflakes": { "enabled": false },
          "pycodestyle": { "enabled": false },
          "mccabe": { "enabled": false },
          "rope_completion": { "enabled": false },
          "yapf": { "enabled": false },
          "autopep8": { "enabled": false },
        },
      },
    },
  },

  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
}
